{
  "version": "1.0.0",
  "schema": "schema/registry.schema.json",
  "slots": [
    "linter",
    "formatter",
    "package_manager",
    "test_runner",
    "styling",
    "framework",
    "runtime",
    "infra",
    "bundler",
    "validation"
  ],
  "languages": {
    "typescript": {
      "display": "TypeScript",
      "path": "languages/typescript/core.md",
      "modules": {
        "eslint": { "slot": "linter", "conflicts_with": ["biome"] },
        "biome": { "slot": "linter", "conflicts_with": ["eslint", "prettier"] },
        "prettier": { "slot": "formatter", "conflicts_with": ["biome"] },
        "bun": { "slot": "package_manager", "conflicts_with": ["npm", "pnpm", "yarn"] },
        "pnpm": { "slot": "package_manager", "conflicts_with": ["npm", "yarn", "bun"] },
        "vitest": { "slot": "test_runner", "conflicts_with": ["jest"] },
        "tailwind": { "slot": "styling" },
        "serverless-framework": { "slot": "infra", "requires": ["aws-lambda"], "conflicts_with": ["sst", "cdk", "sam"] },
        "aws-lambda": { "slot": "runtime", "conflicts_with": ["cloudflare-workers", "vercel-functions"] },
        "esbuild": { "slot": "bundler", "conflicts_with": ["webpack", "rollup", "tsup"] },
        "zod": { "slot": "validation", "conflicts_with": ["io-ts", "yup", "joi"] }
      }
    },
    "javascript": {
      "display": "JavaScript",
      "path": "languages/javascript/core.md",
      "modules": {}
    },
    "python": {
      "display": "Python",
      "path": "languages/python/core.md",
      "modules": {
        "ruff": { "slot": "linter" },
        "black": { "slot": "formatter", "conflicts_with": ["ruff-format"] },
        "poetry": { "slot": "package_manager", "conflicts_with": ["uv", "pdm", "pipenv"] },
        "uv": { "slot": "package_manager", "conflicts_with": ["poetry", "pdm", "pipenv"] },
        "pytest": { "slot": "test_runner" },
        "fastapi": { "slot": "framework" }
      }
    },
    "go": {
      "display": "Go",
      "path": "languages/go/core.md",
      "modules": {}
    },
    "rust": {
      "display": "Rust",
      "path": "languages/rust/core.md",
      "modules": {}
    },
    "java": {
      "display": "Java",
      "path": "languages/java/core.md",
      "modules": {}
    }
  },
  "targets": {
    "claude-code": {
      "display": "Claude Code",
      "output": "CLAUDE.md",
      "template": "targets/claude-code.md.tmpl"
    },
    "cursor": {
      "display": "Cursor",
      "output": ".cursor/rules/ailib.mdc",
      "template": "targets/cursor.mdc.tmpl",
      "frontmatter": {
        "root": "---\ndescription: ailib context router\nalwaysApply: true\n---\n\n",
        "workspace": "---\ndescription: ailib context router\nglobs:\n  - \"./**\"\nalwaysApply: false\n---\n\n"
      }
    },
    "windsurf": {
      "display": "Windsurf",
      "output": ".windsurf/rules/ailib.md",
      "template": "targets/windsurf.md.tmpl",
      "root_output": ".windsurfrules"
    },
    "copilot": {
      "display": "GitHub Copilot",
      "output": ".github/copilot-instructions.md",
      "template": "targets/copilot.md.tmpl",
      "mode": "copilot"
    },
    "jetbrains": {
      "display": "JetBrains AI Assistant",
      "output": ".junie/guidelines.md",
      "template": "targets/jetbrains.md.tmpl"
    },
    "openai": {
      "display": "OpenAI Codex",
      "output": "AGENTS.md",
      "template": "targets/openai.md.tmpl"
    },
    "gemini": {
      "display": "Gemini CLI",
      "output": "GEMINI.md",
      "template": "targets/gemini.md.tmpl"
    }
  }
}
