  "slot_defs": {
    "linter": { "kind": "exclusive", "description": "Primary static analysis tool." },
    "formatter": { "kind": "exclusive", "description": "Primary code formatter." },
    "package_manager": { "kind": "exclusive", "description": "Dependency/package manager." },
    "test_runner": { "kind": "exclusive", "description": "Main unit/integration test runner." },
    "styling_system": { "kind": "exclusive", "description": "Primary CSS styling system." },
    "frontend_framework": { "kind": "exclusive", "description": "Frontend web application framework." },
    "backend_framework": { "kind": "exclusive", "description": "Backend application framework." },
    "ui_library": { "kind": "exclusive", "description": "Primary UI component library/runtime." },
    "http_adapter": { "kind": "exclusive", "description": "HTTP server/adapter runtime." },
    "api_protocol": { "kind": "composable", "description": "API protocol style (REST/GraphQL/etc)." },
    "graphql_server": { "kind": "exclusive", "description": "GraphQL server implementation." },
    "orm": { "kind": "exclusive", "description": "Database ORM/data mapper." },
    "event_bus": { "kind": "exclusive", "description": "Primary event streaming/message bus client." },
    "logger": { "kind": "exclusive", "description": "Structured logging integration." },
    "observability": { "kind": "composable", "description": "Telemetry/tracing integration." },
    "runtime_platform": { "kind": "exclusive", "description": "Compute runtime platform." },
    "infra_framework": { "kind": "exclusive", "description": "Infrastructure/deployment framework." },
    "bundler": { "kind": "exclusive", "description": "Code bundler/build pipeline tool." },
    "schema_validation": { "kind": "exclusive", "description": "General schema validation library." },
    "dto_validation": { "kind": "composable", "description": "DTO/request validation layer." },
    "config_validation": { "kind": "composable", "description": "Configuration/environment validation." },
    "api_docs": { "kind": "composable", "description": "API documentation generator." },
    "cloud_platform": { "kind": "exclusive", "description": "Application cloud platform integration." },
    "payments_provider": { "kind": "exclusive", "description": "Payments platform provider." },
    "database_engine": { "kind": "exclusive", "description": "Primary database engine/service choice." },
    "auth_provider": { "kind": "exclusive", "description": "Authentication/identity provider." },
    "email_provider": { "kind": "exclusive", "description": "Outbound email transport provider." },
    "object_storage_provider": { "kind": "exclusive", "description": "Object storage provider." }
