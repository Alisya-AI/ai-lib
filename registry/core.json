{
  "version": "1.0.0",
  "schema": "schema/registry.schema.json",
  "slots": [
    "linter",
    "formatter",
    "package_manager",
    "test_runner",
    "styling_system",
    "frontend_framework",
    "backend_framework",
    "ui_library",
    "http_adapter",
    "api_protocol",
    "graphql_server",
    "orm",
    "event_bus",
    "logger",
    "observability",
    "runtime_platform",
    "infra_framework",
    "bundler",
    "schema_validation",
    "dto_validation",
    "config_validation",
    "api_docs",
    "cloud_platform",
    "payments_provider",
    "database_engine",
    "auth_provider",
    "email_provider",
    "object_storage_provider"
  ],
  "slot_aliases": {
    "styling": "styling_system",
    "framework": "frontend_framework",
    "http_server": "http_adapter",
    "logging": "logger",
    "runtime": "runtime_platform",
    "infra": "infra_framework",
    "validation": "schema_validation",
    "payments": "payments_provider",
    "database": "database_engine",
    "outbound_email": "email_provider",
    "object_storage": "object_storage_provider"
  },
  "slot_alias_meta": {
    "styling": { "replacement": "styling_system", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "framework": { "replacement": "frontend_framework", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "http_server": { "replacement": "http_adapter", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "logging": { "replacement": "logger", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "runtime": { "replacement": "runtime_platform", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "infra": { "replacement": "infra_framework", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "validation": { "replacement": "schema_validation", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "payments": { "replacement": "payments_provider", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "database": { "replacement": "database_engine", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "outbound_email": { "replacement": "email_provider", "deprecated_since": "1.0.0", "remove_in": "2.0.0" },
    "object_storage": { "replacement": "object_storage_provider", "deprecated_since": "1.0.0", "remove_in": "2.0.0" }
  },
  "slot_defs": {
    "linter": { "kind": "exclusive", "description": "Primary static analysis tool." },
    "formatter": { "kind": "exclusive", "description": "Primary code formatter." },
    "package_manager": { "kind": "exclusive", "description": "Dependency/package manager." },
    "test_runner": { "kind": "exclusive", "description": "Main unit/integration test runner." },
    "styling_system": { "kind": "exclusive", "description": "Primary CSS styling system." },
    "frontend_framework": { "kind": "exclusive", "description": "Frontend web application framework." },
    "backend_framework": { "kind": "exclusive", "description": "Backend application framework." },
    "ui_library": { "kind": "exclusive", "description": "Primary UI component library/runtime." },
    "http_adapter": { "kind": "exclusive", "description": "HTTP server/adapter runtime." },
    "api_protocol": { "kind": "composable", "description": "API protocol style (REST/GraphQL/etc)." },
    "graphql_server": { "kind": "exclusive", "description": "GraphQL server implementation." },
    "orm": { "kind": "exclusive", "description": "Database ORM/data mapper." },
    "event_bus": { "kind": "exclusive", "description": "Primary event streaming/message bus client." },
    "logger": { "kind": "exclusive", "description": "Structured logging integration." },
    "observability": { "kind": "composable", "description": "Telemetry/tracing integration." },
    "runtime_platform": { "kind": "exclusive", "description": "Compute runtime platform." },
    "infra_framework": { "kind": "exclusive", "description": "Infrastructure/deployment framework." },
    "bundler": { "kind": "exclusive", "description": "Code bundler/build pipeline tool." },
    "schema_validation": { "kind": "exclusive", "description": "General schema validation library." },
    "dto_validation": { "kind": "composable", "description": "DTO/request validation layer." },
    "config_validation": { "kind": "composable", "description": "Configuration/environment validation." },
    "api_docs": { "kind": "composable", "description": "API documentation generator." },
    "cloud_platform": { "kind": "exclusive", "description": "Application cloud platform integration." },
    "payments_provider": { "kind": "exclusive", "description": "Payments platform provider." },
    "database_engine": { "kind": "exclusive", "description": "Primary database engine/service choice." },
    "auth_provider": { "kind": "exclusive", "description": "Authentication/identity provider." },
    "email_provider": { "kind": "exclusive", "description": "Outbound email transport provider." },
    "object_storage_provider": { "kind": "exclusive", "description": "Object storage provider." }
  },
  "targets": {
    "claude-code": {
      "display": "Claude Code",
      "output": "CLAUDE.md",
      "template": "targets/claude-code.md.tmpl"
    },
    "cursor": {
      "display": "Cursor",
      "output": ".cursor/rules/ailib.mdc",
      "template": "targets/cursor.mdc.tmpl",
      "frontmatter": {
        "root": "---\ndescription: ailib context router\nalwaysApply: true\n---\n\n",
        "workspace": "---\ndescription: ailib context router\nglobs:\n  - \"./**\"\nalwaysApply: false\n---\n\n"
      }
    },
    "windsurf": {
      "display": "Windsurf",
      "output": ".windsurf/rules/ailib.md",
      "template": "targets/windsurf.md.tmpl",
      "root_output": ".windsurfrules"
    },
    "copilot": {
      "display": "GitHub Copilot",
      "output": ".github/copilot-instructions.md",
      "template": "targets/copilot.md.tmpl",
      "mode": "copilot"
    },
    "jetbrains": {
      "display": "JetBrains AI Assistant",
      "output": ".junie/guidelines.md",
      "template": "targets/jetbrains.md.tmpl"
    },
    "openai": {
      "display": "OpenAI Codex",
      "output": "AGENTS.md",
      "template": "targets/openai.md.tmpl"
    },
    "gemini": {
      "display": "Gemini CLI",
      "output": "GEMINI.md",
      "template": "targets/gemini.md.tmpl"
    }
  },
  "skills": {
    "architecture-decision-flow": {
      "display": "Architecture decision flow",
      "description": "Drive architecture decisions end-to-end using RFC and DACI, from problem framing to rollout review.",
      "path": "skills/architecture-decision-flow.md",
      "compatible": {
        "languages": ["typescript", "python", "go", "java", "rust", "javascript"],
        "targets": ["cursor", "claude-code", "copilot", "openai", "gemini", "windsurf", "jetbrains"]
      }
    },
    "rfc-authoring": {
      "display": "RFC authoring",
      "description": "Write concise RFCs with context, options, tradeoffs, recommendation, and rollout planning.",
      "path": "skills/rfc-authoring.md",
      "requires": ["architecture-decision-flow"],
      "compatible": {
        "languages": ["typescript", "python", "go", "java", "rust", "javascript"],
        "targets": ["cursor", "claude-code", "copilot", "openai", "gemini", "windsurf", "jetbrains"]
      }
    },
    "daci-facilitation": {
      "display": "DACI facilitation",
      "description": "Establish DACI ownership and run efficient decision reviews with clear accountability.",
      "path": "skills/daci-facilitation.md",
      "requires": ["architecture-decision-flow"],
      "compatible": {
        "languages": ["typescript", "python", "go", "java", "rust", "javascript"],
        "targets": ["cursor", "claude-code", "copilot", "openai", "gemini", "windsurf", "jetbrains"]
      }
    },
    "design-review-checklist": {
      "display": "Design review checklist",
      "description": "Run consistent technical design reviews for correctness, operability, security, and maintainability.",
      "path": "skills/design-review-checklist.md",
      "compatible": {
        "languages": ["typescript", "python", "go", "java", "rust", "javascript"],
        "targets": ["cursor", "claude-code", "copilot", "openai", "gemini", "windsurf", "jetbrains"]
      }
    },
    "delivery-flow-refinement": {
      "display": "Delivery flow refinement",
      "description": "Improve software delivery flow by reducing bottlenecks across planning, implementation, review, and release.",
      "path": "skills/delivery-flow-refinement.md",
      "compatible": {
        "languages": ["typescript", "python", "go", "java", "rust", "javascript"],
        "targets": ["cursor", "claude-code", "copilot", "openai", "gemini", "windsurf", "jetbrains"]
      }
    }
  }
}
