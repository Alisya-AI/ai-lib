{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/tools",
    "rootDir": "tools",
    "types": ["node"],
    "strict": false,
    "allowJs": false,
    "declaration": false,
    "sourceMap": false,
    "skipLibCheck": true
  },
  "include": ["tools/**/*.ts"]
}
