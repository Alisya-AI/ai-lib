{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "strict": false,
    "noEmit": true,
    "allowJs": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "tools/**/*.mjs", "test/**/*.ts"]
}
